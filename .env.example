# === API C# ===
DATABASE_URL=Host=localhost;Database=invest_dev;Username=postgres;Password=troque-por-uma-senha-segura
JWT_SECRET=sua-chave-secreta-aqui-minimo-32-caracteres
JWT_EXPIRATION=24h
CORS_ORIGINS=http://localhost:5173

# === Batch Python ===
# DATABASE_URL=postgresql://postgres:troque-por-uma-senha-segura@localhost:5432/invest_dev
