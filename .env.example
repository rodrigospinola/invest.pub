VERTEX_AI_LOCATION=us-central1

# === Vertex AI Model ===
VERTEX_AI_MODEL=gemini-2.5-flash

# === Gemini API Key (alternativa ao Vertex AI — grátis em aistudio.google.com/apikey) ===
